{
  "name": "telegram-quiz-bot",
  "version": "1.0.0",
  "description": "Send interactive quizzes to Telegram",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx index.ts api",
    "start": "node dist/index.js api",
    "heroku-postbuild": "npm run build",
    "send-all": "node dist/index.js send-all",
    "worker": "RUN_QUEUE_WORKER=true node dist/index.js api"
  },
  "keywords": [
    "telegram",
    "bot",
    "quiz",
    "poll"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bullmq": "^5.8.1",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "form-data": "^4.0.5",
    "ioredis": "^5.4.1",
    "mongodb": "^7.1.1",
    "multer": "^1.4.5-lts.1",
    "streamifier": "^0.1.1",
    "winston": "^3.17.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  }
}
